// runtime.tc — TinyC runtime for RISC-V bare-metal
// kmalloc/kfree allocator + builtins. Uses peek/poke for low-level memory access.
// Syscalls via do_write/do_read/do_exit stubs in crt0.s.
//
// BSS arena layout (__runtime_init receives bss_start and bss_size):
//
//   bss_start
//   +0     bucket_table[10]   40 bytes  — free list heads for 10 size classes
//   +40    heap region                   — managed by large free list
//   ...
//   bss_start + bss_size
//
//   bucket_table[i] (u32): head of singly-linked free list for bucket i.
//   Each free node is an in-place block whose first 4 bytes point to next.
//
//   heap region: one or more free/allocated blocks, each prefixed by a
//   4-byte header storing the block's total size (header + user data).
//
//   Allocated block:  [total_size: u32] [user data ...]
//   Free block:       [total_size: u32] [next_free: u32] [unused ...]
//   Bucket free node: [next_free: u32]  (size implicit from bucket index)
//
// Allocator design:
//   10 small-size buckets (4,8,16,32,64,128,256,512,1024,2048) with per-bucket
//   free lists for O(1) alloc/free. Buckets are NOT pre-populated; blocks are
//   carved from the large free list on first use.
//   Allocations > 2048: first-fit free list, address-ordered, coalescing on free.
//   Allocations >= 4096: user size rounded up to 4KB granularity.

var KM_HDR: i32 = 4;
var KM_MIN_BLK: i32 = 8;
var KM_PAGE: i32 = 4096;
var KM_NBUCKETS: i32 = 10;

var g_bucket_base: u32 = 0u32;
var g_free_list: u32 = 0u32;

fn km_align4(n: i32) -> i32 { return (n + 3) & (0 - 4); }
fn km_align_page(n: i32) -> i32 { return (n + 4095) & (0 - 4096); }

fn bk_get(i: i32) -> u32 { return peek32(g_bucket_base + (i * 4) as u32); }
fn bk_set(i: i32, v: u32) -> void { poke32(g_bucket_base + (i * 4) as u32, v); return; }

fn size_to_bucket(size: i32) -> i32 {
    if size <= 4 { return 0; }
    if size <= 8 { return 1; }
    if size <= 16 { return 2; }
    if size <= 32 { return 3; }
    if size <= 64 { return 4; }
    if size <= 128 { return 5; }
    if size <= 256 { return 6; }
    if size <= 512 { return 7; }
    if size <= 1024 { return 8; }
    if size <= 2048 { return 9; }
    return 0 - 1;
}

fn bucket_user_size(b: i32) -> i32 {
    if b == 0 { return 4; }
    if b == 1 { return 8; }
    if b == 2 { return 16; }
    if b == 3 { return 32; }
    if b == 4 { return 64; }
    if b == 5 { return 128; }
    if b == 6 { return 256; }
    if b == 7 { return 512; }
    if b == 8 { return 1024; }
    return 2048;
}

// large_alloc — first-fit allocator on an address-ordered free list.
//
// g_free_list はアドレス昇順に並んだフリーブロックの連結リスト。
// 各フリーブロックの構造:  [total_size: u32] [next: u32] [unused ...]
//
// 1. リストを先頭から走査し、need バイト以上の最初のブロックを探す (first-fit)。
// 2. 見つかったブロックが need + KM_MIN_BLK 以上なら分割:
//    - ブロック前半 (need バイト) を確保用に切り出す
//    - 後半を新しいフリーブロックとしてリストに残す
//    見つかったブロックが分割するには小さすぎる場合、ブロック全体を使う。
// 3. 確保したブロックのヘッダに total_size を書き込み、
//    ヘッダ直後 (cur + KM_HDR) をユーザポインタとして返す。
// 4. 見つからなければ 0 (OOM) を返す。
//
// 図 (分割の場合):
//   before: [    bsz    |next|  ...  ]
//   after:  [need|data..][remain|next| ...]
//            ^返却         ^リストに残る
fn large_alloc(need: i32) -> u32 {
    var prev: u32 = 0u32;
    var cur: u32 = g_free_list;
    while cur != 0u32 {
        var bsz: i32 = peek32(cur) as i32;
        if bsz >= need {
            var remain: i32 = bsz - need;
            if remain >= KM_MIN_BLK {
                // 分割: 後半を新フリーブロックにしてリストに繋ぎ替え
                var nb: u32 = cur + need as u32;
                poke32(nb, remain as u32);
                poke32(nb + 4u32, peek32(cur + 4u32));
                poke32(cur, need as u32);
                if prev == 0u32 {
                    g_free_list = nb;
                } else {
                    poke32(prev + 4u32, nb as u32);
                }
            } else {
                // 分割不可: ブロック全体を使い、リストから外す
                var nxt: u32 = peek32(cur + 4u32);
                if prev == 0u32 {
                    g_free_list = nxt;
                } else {
                    poke32(prev + 4u32, nxt);
                }
            }
            return cur + KM_HDR as u32;
        }
        prev = cur;
        cur = peek32(cur + 4u32);
    }
    return 0u32;
}

// large_free — アドレス順フリーリストにブロックを返却し、隣接結合する。
//
// 1. リストを走査して blk のアドレス順の挿入位置を探す。
//    走査後: prev = blk より前のブロック (なければ 0)
//            cur  = blk より後のブロック (なければ 0)
//
// 2. 後方結合: blk の末尾 (blk + bsz) が cur と一致すれば、
//    blk と cur を 1 つのブロックに統合する。
//    一致しなければ blk.next = cur としてリストに挿入。
//
// 3. 前方結合: prev の末尾 (prev + prev.size) が blk と一致すれば、
//    prev と blk を 1 つのブロックに統合する。
//    一致しなければ prev.next = blk としてリストに挿入。
//
// 図 (前後とも結合する場合):
//   before: ... [prev|next] ... [blk] ... [cur|next] ...
//   after:  ... [prev+blk+cur|next] ...
fn large_free(blk: u32, bsz: i32) -> void {
    var bend: u32 = blk + bsz as u32;
    var prev: u32 = 0u32;
    var cur: u32 = g_free_list;
    // 挿入位置を探す (アドレス昇順)
    while cur != 0u32 && cur < blk {
        prev = cur;
        cur = peek32(cur + 4u32);
    }
    // 後方結合: blk の直後が cur なら統合
    if cur != 0u32 && bend == cur {
        var csz: i32 = peek32(cur) as i32;
        var cnxt: u32 = peek32(cur + 4u32);
        poke32(blk, (bsz + csz) as u32);
        poke32(blk + 4u32, cnxt);
    } else {
        poke32(blk + 4u32, cur as u32);
    }
    // 前方結合: prev の直後が blk なら統合
    if prev != 0u32 {
        var psz: i32 = peek32(prev) as i32;
        var pend: u32 = prev + psz as u32;
        if pend == blk {
            var msz: i32 = psz + peek32(blk) as i32;
            poke32(prev, msz as u32);
            poke32(prev + 4u32, peek32(blk + 4u32));
        } else {
            poke32(prev + 4u32, blk as u32);
        }
    } else {
        g_free_list = blk;
    }
    return;
}

// kmalloc — size バイトのメモリを確保し、ユーザポインタを返す。
//
// 1. size がバケット範囲内 (≤ 2048) の場合:
//    a. 該当バケットのフリーリストにノードがあれば pop して O(1) で返す。
//       ノードにはヘッダ (total_size) を書き込んでから返却する。
//       これは kfree 時にバケット判定に使うため。
//    b. フリーリストが空なら large_alloc でヒープから切り出す。
//
// 2. size がバケット範囲外 (> 2048) の場合:
//    - size >= 4096: ユーザサイズを 4KB 粒度に切り上げ + ヘッダ
//    - それ以外: 4 バイトアラインに切り上げ + ヘッダ (最小 8 バイト)
//    large_alloc で確保する。
//
// 返却値: ユーザデータ先頭 (ヘッダの直後)。OOM なら 0。
fn kmalloc(size: i32) -> u32 {
    if size <= 0 { size = 1; }
    var bkt: i32 = size_to_bucket(size);
    if bkt >= 0 {
        // バケットフリーリストから O(1) で取得を試みる
        var head: u32 = bk_get(bkt);
        if head != 0u32 {
            bk_set(bkt, peek32(head));
            var total: i32 = bucket_user_size(bkt) + KM_HDR;
            poke32(head, total as u32);
            return head + KM_HDR as u32;
        }
        // バケット空 → ヒープから切り出し
        var total: i32 = bucket_user_size(bkt) + KM_HDR;
        return large_alloc(total);
    }
    // バケット範囲外 → large_alloc
    var need: i32;
    if size >= KM_PAGE {
        need = km_align_page(size) + KM_HDR;
    } else {
        need = km_align4(size + KM_HDR);
        if need < KM_MIN_BLK { need = KM_MIN_BLK; }
    }
    return large_alloc(need);
}

// kfree — kmalloc で確保したポインタを解放する。
//
// 1. ptr の直前 4 バイト (ヘッダ) から total_size を読む。
// 2. total_size - KM_HDR がバケットサイズと一致すれば、
//    該当バケットのフリーリストに push して O(1) で完了。
//    (ヘッダ領域を next ポインタとして再利用する)
// 3. 一致しなければ large_free でヒープに返却 (隣接結合���り)。
fn kfree(ptr: u32) -> void {
    if ptr == 0u32 { return; }
    var blk: u32 = ptr - KM_HDR as u32;
    var total: i32 = peek32(blk) as i32;
    var user: i32 = total - KM_HDR;
    var bkt: i32 = size_to_bucket(user);
    if bkt >= 0 && bucket_user_size(bkt) == user {
        // バケットフリーリストに push (O(1))
        poke32(blk, bk_get(bkt));
        bk_set(bkt, blk);
        return;
    }
    // 大ブロック → ヒープに返却 (隣接結合)
    large_free(blk, total);
    return;
}

export fn __runtime_init(bss: u32, bss_size: i32) -> void {
    g_bucket_base = bss;
    var i: i32 = 0;
    while i < KM_NBUCKETS {
        poke32(bss + (i * 4) as u32, 0u32);
        i = i + 1;
    }
    var heap: u32 = bss + (KM_NBUCKETS * 4) as u32;
    var hsz: i32 = bss_size - KM_NBUCKETS * 4;
    hsz = hsz & (0 - 4);
    if hsz >= KM_MIN_BLK {
        poke32(heap, hsz as u32);
        poke32(heap + 4u32, 0u32);
        g_free_list = heap;
    }
    return;
}

// ===== HeapObj: count-prefixed allocation =====
fn new_array(count: i32, data_bytes: i32) -> u32 {
    var total: i32 = 4 + data_bytes;
    if total < 4 { total = 4; }
    var addr: u32 = kmalloc(total);
    if addr == 0u32 { do_exit(1); }
    var ztotal: i32 = (total + 3) & (0 - 4);
    var k: i32 = 0;
    while k < ztotal { poke32(addr + k as u32, 0u32); k = k + 4; }
    poke32(addr, count as u32);
    return addr;
}

// ===== Array constructors =====
export fn U8Array(sz: i32) -> U8Array { return new_array(sz, sz) as U8Array; }
export fn U16Array(sz: i32) -> U16Array { return new_array(sz, sz * 2) as U16Array; }
export fn U32Array(sz: i32) -> U32Array { return new_array(sz, sz * 4) as U32Array; }
export fn I8Array(sz: i32) -> I8Array { return new_array(sz, sz) as I8Array; }
export fn I16Array(sz: i32) -> I16Array { return new_array(sz, sz * 2) as I16Array; }
export fn I32Array(sz: i32) -> I32Array { return new_array(sz, sz * 4) as I32Array; }
export fn StringArray(sz: i32) -> StringArray { return new_array(sz, sz * 4) as StringArray; }

// ===== len =====
export fn len(o: U8Array) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }
export fn len(o: U16Array) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }
export fn len(o: U32Array) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }
export fn len(o: I8Array) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }
export fn len(o: I16Array) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }
export fn len(o: I32Array) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }
export fn len(o: StringArray) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }
export fn len(o: String) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }
export fn len(o: StringLiteral) -> i32 { if o as u32 == 0u32 { return 0; } return peek32(o as u32) as i32; }

// ===== get =====
export fn get(o: U8Array, i: i32) -> u8 { return peek8(o as u32 + 4u32 + i as u32) as u8; }
export fn get(o: U16Array, i: i32) -> u16 { return peek16(o as u32 + 4u32 + (i * 2) as u32) as u16; }
export fn get(o: U32Array, i: i32) -> u32 { return peek32(o as u32 + 4u32 + (i * 4) as u32); }
export fn get(o: I8Array, i: i32) -> i8 { return peek8(o as u32 + 4u32 + i as u32) as i8; }
export fn get(o: I16Array, i: i32) -> i16 { return peek16(o as u32 + 4u32 + (i * 2) as u32) as i16; }
export fn get(o: I32Array, i: i32) -> i32 { return peek32(o as u32 + 4u32 + (i * 4) as u32) as i32; }
export fn get(o: StringArray, i: i32) -> String { return peek32(o as u32 + 4u32 + (i * 4) as u32) as String; }
export fn get(o: String, i: i32) -> u8 { return peek8(o as u32 + 4u32 + i as u32) as u8; }
export fn get(o: StringLiteral, i: i32) -> u8 { return peek8(o as u32 + 4u32 + i as u32) as u8; }

// ===== set =====
export fn set(o: U8Array, i: i32, v: u8) -> void { poke8(o as u32 + 4u32 + i as u32, v as u8); return; }
export fn set(o: U16Array, i: i32, v: u16) -> void { poke16(o as u32 + 4u32 + (i*2) as u32, v as u16); return; }
export fn set(o: U32Array, i: i32, v: u32) -> void { poke32(o as u32 + 4u32 + (i*4) as u32, v); return; }
export fn set(o: I8Array, i: i32, v: i8) -> void { poke8(o as u32 + 4u32 + i as u32, v as u8); return; }
export fn set(o: I16Array, i: i32, v: i16) -> void { poke16(o as u32 + 4u32 + (i*2) as u32, v as u16); return; }
export fn set(o: I32Array, i: i32, v: i32) -> void { poke32(o as u32 + 4u32 + (i*4) as u32, v as u32); return; }
export fn set(o: StringArray, i: i32, v: String) -> void { poke32(o as u32 + 4u32 + (i*4) as u32, v as u32); return; }
export fn set(o: StringArray, i: i32, v: StringLiteral) -> void { poke32(o as u32 + 4u32 + (i*4) as u32, v as u32); return; }

// ===== delete =====
fn delete_impl(o: u32) -> void { if o == 0u32 { return; } kfree(o); return; }
export fn delete(o: U8Array) -> void { delete_impl(o as u32); return; }
export fn delete(o: U16Array) -> void { delete_impl(o as u32); return; }
export fn delete(o: U32Array) -> void { delete_impl(o as u32); return; }
export fn delete(o: I8Array) -> void { delete_impl(o as u32); return; }
export fn delete(o: I16Array) -> void { delete_impl(o as u32); return; }
export fn delete(o: I32Array) -> void { delete_impl(o as u32); return; }
export fn delete(o: StringArray) -> void { delete_impl(o as u32); return; }
export fn delete(o: String) -> void { delete_impl(o as u32); return; }
export fn delete(o: StringLiteral) -> void { return; }

export fn heap_mark() -> i32 { return 0; }
export fn heap_reset(mark: i32) -> void { return; }

// ===== sys_write / sys_read / sys_exit =====
export fn sys_write(fd: i32, buf: U8Array, slen: i32) -> i32 {
    if buf as u32 == 0u32 { return 0 - 1; }
    var count: i32 = peek32(buf as u32) as i32;
    if slen < count { count = slen; }
    var data: u32 = buf as u32 + 4u32;
    return do_write(fd, data, count);
}

export fn sys_read(fd: i32, buf: U8Array, slen: i32) -> i32 {
    if buf as u32 == 0u32 { return 0 - 1; }
    var count: i32 = peek32(buf as u32) as i32;
    if slen < count { count = slen; }
    var data: u32 = buf as u32 + 4u32;
    var total: i32 = 0;
    while total < count {
        var r: i32 = do_read(fd, data + total as u32, count - total);
        if r <= 0 { return total; }
        total = total + r;
    }
    return total;
}

export fn sys_exit(code: i32) -> void { do_exit(code); return; }

// ===== Print helpers =====
export fn print_i32(v: i32) -> void {
    var buf: U8Array = U8Array(16);
    var neg: i32 = 0;
    if v < 0 { neg = 1; v = 0 - v; }
    if v == 0 {
        poke8(buf as u32 + 4u32 + (0) as u32, ('0') as u8); poke8(buf as u32 + 4u32 + (1) as u32, (10u8) as u8);
        sys_write(1, buf, 2);
        delete_impl(buf as u32);
        return;
    }
    var tmp: U8Array = U8Array(12);
    var i: i32 = 0;
    while v > 0 { poke8(tmp as u32 + 4u32 + (i) as u32, ((48 + v % 10) as u8) as u8); i = i + 1; v = v / 10; }
    var pos: i32 = 0;
    if neg == 1 { poke8(buf as u32 + 4u32 + (pos) as u32, ('-') as u8); pos = pos + 1; }
    var j: i32 = i - 1;
    while j >= 0 { poke8(buf as u32 + 4u32 + (pos) as u32, (peek8(tmp as u32 + 4u32 + (j) as u32) as u8 as u8)); pos = pos + 1; j = j - 1; }
    poke8(buf as u32 + 4u32 + (pos) as u32, (10u8) as u8); pos = pos + 1;
    sys_write(1, buf, pos);
    delete_impl(tmp as u32);
    delete_impl(buf as u32);
    return;
}
export fn print_u32(v: u32) -> void { print_i32(v as i32); return; }
export fn print_bool(v: bool) -> void {
    if v { print_i32(1); } else { print_i32(0); }
    return;
}
export fn print_str(s: String) -> void {
    if s as u32 != 0u32 {
        var slen: i32 = peek32(s as u32) as i32;
        do_write(1, s as u32 + 4u32, slen);
    }
    do_write(1, 0u32, 0);
    var nl: U8Array = U8Array(1);
    poke8(nl as u32 + 4u32 + (0) as u32, (10u8) as u8);
    sys_write(1, nl, 1);
    delete_impl(nl as u32);
    return;
}
export fn print_str(s: StringLiteral) -> void { print_str(s as String); return; }

// ===== String operations =====
export fn append(s: String, c: u8) -> String {
    var sl: i32 = 0;
    if s as u32 != 0u32 { sl = peek32(s as u32) as i32; }
    var addr: u32 = new_array(sl + 1, sl + 2);
    var i: i32 = 0;
    while i < sl { poke8(addr + 4u32 + i as u32, peek8(s as u32 + 4u32 + i as u32) as u8); i = i + 1; }
    poke8(addr + 4u32 + sl as u32, c as u8);
    poke8(addr + 4u32 + (sl + 1) as u32, 0u8);
    return addr as String;
}
export fn append(s: String, t: String) -> String {
    var sl: i32 = 0; var tl: i32 = 0;
    if s as u32 != 0u32 { sl = peek32(s as u32) as i32; }
    if t as u32 != 0u32 { tl = peek32(t as u32) as i32; }
    var addr: u32 = new_array(sl + tl, sl + tl + 1);
    var i: i32 = 0;
    while i < sl { poke8(addr + 4u32 + i as u32, peek8(s as u32 + 4u32 + i as u32) as u8); i = i + 1; }
    i = 0;
    while i < tl { poke8(addr + 4u32 + (sl + i) as u32, peek8(t as u32 + 4u32 + i as u32) as u8); i = i + 1; }
    poke8(addr + 4u32 + (sl + tl) as u32, 0u8);
    return addr as String;
}
export fn append(s: StringLiteral, c: u8) -> String { return append(s as String, c); }
export fn append(s: StringLiteral, t: StringLiteral) -> String { return append(s as String, t as String); }
export fn append(s: StringLiteral, t: String) -> String { return append(s as String, t); }
export fn append(s: String, t: StringLiteral) -> String { return append(s, t as String); }

export fn equals(s: String, t: String) -> bool {
    if s as u32 == 0u32 || t as u32 == 0u32 { return s as u32 == t as u32; }
    var sl: i32 = peek32(s as u32) as i32;
    var tl: i32 = peek32(t as u32) as i32;
    if sl != tl { return false; }
    var i: i32 = 0;
    while i < sl {
        if peek8(s as u32 + 4u32 + i as u32) != peek8(t as u32 + 4u32 + i as u32) { return false; }
        i = i + 1;
    }
    return true;
}
export fn equals(s: StringLiteral, t: StringLiteral) -> bool { return equals(s as String, t as String); }
export fn equals(s: StringLiteral, t: String) -> bool { return equals(s as String, t); }
export fn equals(s: String, t: StringLiteral) -> bool { return equals(s, t as String); }
