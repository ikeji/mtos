.bc
; string table
.string 0 "Hello, World\n"

.fn to_buf String void
.param str String
.local len i32
.local buf U8Array
.local i i32
; var len: i32 = len(str);
  load str
  call len String
  store len
; var buf: U8Array = U8Array(13);
  push_int 13
  call U8Array i32
  store buf
; var i: i32 = 0;
  push_int 0
  store i
; while i < len {
__L0:
  load i
  load len
  lt
  jump_ifnot __L1
; set(buf, i, get(str, i));
  load buf
  load i
  load str
  load i
  call get String i32
  call set U8Array i32 u8
  pop
; i = i + 1;
  load i
  push_int 1
  add
  store i
  jump __L0
__L1:
; return buf;
  load buf
  return
  return_void
.endfn

.fn main i32
.local buf U8Array
; var buf: U8Array = to_buf("Hello, World\n");
  push_str 0
  call to_buf String
  store buf
; sys_write(1, buf, 13);
  push_int 1
  load buf
  push_int 13
  call sys_write i32 U8Array i32
  pop
; delete(buf);
  load buf
  call delete U8Array
  pop
; return 0;
  push_int 0
  return
  return_void
.endfn

.endbc
