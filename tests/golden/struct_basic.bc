.bc
.fn Point i32 i32 Point
.param __a0 i32
.param __a1 i32
.local __p U32Array
; struct Point { x: i32, y: i32 }
  push_int 2
  call U32Array i32
  store __p
; struct Point { x: i32, y: i32 }
  load __p
  push_int 0
  load __a0
  cast u32
  call set U32Array i32 u32
  pop
; struct Point { x: i32, y: i32 }
  load __p
  push_int 1
  load __a1
  cast u32
  call set U32Array i32 u32
  pop
; struct Point { x: i32, y: i32 }
  load __p
  return
  return_void
.endfn

.fn x Point i32
.param __p Point
; struct Point { x: i32, y: i32 }
  load __p
  push_int 0
  call get U32Array i32
  cast i32
  return
  return_void
.endfn

.fn y Point i32
.param __p Point
; struct Point { x: i32, y: i32 }
  load __p
  push_int 1
  call get U32Array i32
  cast i32
  return
  return_void
.endfn

.fn x Point i32 void
.param __p Point
.param __v i32
; struct Point { x: i32, y: i32 }
  load __p
  push_int 0
  load __v
  cast u32
  call set U32Array i32 u32
  pop
; struct Point { x: i32, y: i32 }
  return_void
  return_void
.endfn

.fn y Point i32 void
.param __p Point
.param __v i32
; struct Point { x: i32, y: i32 }
  load __p
  push_int 1
  load __v
  cast u32
  call set U32Array i32 u32
  pop
; struct Point { x: i32, y: i32 }
  return_void
  return_void
.endfn

.fn main i32
.local p Point
; var p: Point = Point(3, 4);
  push_int 3
  push_int 4
  call Point i32 i32
  store p
; print_i32(x(p));
  load p
  call x Point
  call print_i32 i32
  pop
; print_i32(y(p));
  load p
  call y Point
  call print_i32 i32
  pop
; x(p, 10);
  load p
  push_int 10
  call x Point i32
  pop
; y(p, 20);
  load p
  push_int 20
  call y Point i32
  pop
; print_i32(x(p) + y(p));
  load p
  call x Point
  load p
  call y Point
  add
  call print_i32 i32
  pop
; delete(p);
  load p
  call delete Point
  pop
; return 0;
  push_int 0
  return
  return_void
.endfn

.endbc
