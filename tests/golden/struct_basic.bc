.bc
.fn Point i32 i32 Point
.param __a0 i32
.param __a1 i32
.local __p U32Array
  push_int 2
  call U32Array u32
  store __p
  load __p
  push_int 0
  load __a0
  cast u32
  call set U32Array i32 u32
  pop
  load __p
  push_int 1
  load __a1
  cast u32
  call set U32Array i32 u32
  pop
  load __p
  return
  return_void
.endfn

.fn x Point i32
.param __p Point
  load __p
  push_int 0
  call get U32Array i32
  cast i32
  return
  return_void
.endfn

.fn y Point i32
.param __p Point
  load __p
  push_int 1
  call get U32Array i32
  cast i32
  return
  return_void
.endfn

.fn x Point i32 void
.param __p Point
.param __v i32
  load __p
  push_int 0
  load __v
  cast u32
  call set U32Array i32 u32
  pop
  return_void
  return_void
.endfn

.fn y Point i32 void
.param __p Point
.param __v i32
  load __p
  push_int 1
  load __v
  cast u32
  call set U32Array i32 u32
  pop
  return_void
  return_void
.endfn

.fn delete Point void
.param __p Point
  load __p
  call delete U32Array
  pop
  return_void
  return_void
.endfn

.fn PointArray u32 PointArray
.param __n u32
  load __n
  call U32Array u32
  return
  return_void
.endfn

.fn len PointArray i32
.param __a PointArray
  load __a
  call len U32Array
  return
  return_void
.endfn

.fn get PointArray i32 Point
.param __a PointArray
.param __i i32
  load __a
  load __i
  call get U32Array i32
  return
  return_void
.endfn

.fn set PointArray i32 Point void
.param __a PointArray
.param __i i32
.param __v Point
  load __a
  load __i
  load __v
  cast u32
  call set U32Array i32 u32
  pop
  return_void
  return_void
.endfn

.fn delete PointArray void
