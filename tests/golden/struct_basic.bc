  call delete U32Array
  pop
  return_void
  return_void
.endfn

.fn main i32
.local p Point
; var p: Point = Point(3, 4);
  push_int 3
  push_int 4
  call Point i32 i32
  store p
; print_i32(x(p));
  load p
  call x Point
  call print_i32 i32
  pop
; print_i32(y(p));
  load p
  call y Point
  call print_i32 i32
  pop
; x(p, 10);
  load p
  push_int 10
  call x Point i32
  pop
; y(p, 20);
  load p
  push_int 20
  call y Point i32
  pop
; print_i32(x(p) + y(p));
  load p
  call x Point
  load p
  call y Point
  add
  call print_i32 i32
  pop
; delete(p);
  load p
  call delete Point
  pop
; return 0;
  push_int 0
  return
  return_void
.endfn

