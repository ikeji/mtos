.bc
.fn fib i32 i32
.param n i32
; if n <= 1 {
  load n
  push_int 1
  le
  jump_ifnot __L0
; return n;
  load n
  return
__L0:
; return fib(n - 1) + fib(n - 2);
  load n
  push_int 1
  sub
  call fib i32
  load n
  push_int 2
  sub
  call fib i32
  add
  return
  return_void
.endfn

.fn main i32
.local result i32
; var result: i32 = fib(10);
  push_int 10
  call fib i32
  store result
; print(result);
  load result
  call print i32
  pop
; return result;
  load result
  return
  return_void
.endfn

.endbc
