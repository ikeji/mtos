.fn fn_name_ss I32Array i32 i32
.param fns I32Array
.param fi i32
; fn fn_name_ss(fns: I32Array, fi: i32) -> i32 { return get(fns, (fi*10+0)); }
  load fns
  load fi
  push_int 10
  mul
  push_int 0
  add
  call get I32Array i32
  return
  return_void
.endfn

