.param fi i32
; fn fn_name_sl(fns: I32Array, fi: i32) -> i32 { return get(fns, (fi*10+1)); }
  load fns
  load fi
  push_int 10
  mul
  push_int 1
  add
  call get I32Array i32
  return
  return_void
.endfn

