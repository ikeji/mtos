  call ob_flush U8Array
  pop
  load in_buf
  call delete U8Array
  pop
  load atom_buf
  call delete U8Array
  pop
  load out_buf
  call delete U8Array
  pop
  load nodes
  call delete I32Array
  pop
  load strtab
  call delete U8Array
  pop
  load slits
  call delete I32Array
  pop
  load locals
  call delete I32Array
  pop
  push_int 0
  return
  return_void
.endfn

.endbc
