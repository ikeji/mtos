.fn ob_flush 1 void
.param ob U8Array
; if g_ob_pos > 0 { sys_write(1, ob, g_ob_pos as u32); g_ob_pos = 0; }
  load g_ob_pos
  push_int 0
  gt
  jump_ifnot __L0
; if g_ob_pos > 0 { sys_write(1, ob, g_ob_pos as u32); g_ob_pos = 0; }
  push_int 1
  load ob
  load g_ob_pos
  cast u32
  call sys_write 3
  pop
; if g_ob_pos > 0 { sys_write(1, ob, g_ob_pos as u32); g_ob_pos = 0; }
  push_int 0
  store g_ob_pos
__L0:
; return;
  return_void
  return_void
.endfn

.fn ob_char 2 void
.param c u8
.param ob U8Array
; set(ob, g_ob_pos as u32, c);
  load ob
  load g_ob_pos
  cast u32
  load c
  call set 3
  pop
; g_ob_pos = g_ob_pos + 1;
  load g_ob_pos
  push_int 1
  add
  store g_ob_pos
; if g_ob_pos >= 8192 { ob_flush(ob); }
  load g_ob_pos
  push_int 8192
  ge
  jump_ifnot __L1
; if g_ob_pos >= 8192 { ob_flush(ob); }
  load ob
  call ob_flush 1
  pop
__L1:
; return;
  return_void
  return_void
.endfn

.fn ob_n 4 void
.param src U8Array
.param start i32
.param n i32
.param ob U8Array
.local i i32
; var i: i32 = 0;
  push_int 0
  store i
; while i < n { ob_char(get(src,(start+i) as u32), ob); i = i + 1; }
__L2:
  load i
  load n
  lt
  jump_ifnot __L3
; while i < n { ob_char(get(src,(start+i) as u32), ob); i = i + 1; }
  load src
  load start
  load i
  add
  cast u32
  call get 2
  load ob
  call ob_char 2
  pop
; while i < n { ob_char(get(src,(start+i) as u32), ob); i = i + 1; }
  load i
  push_int 1
  add
  store i
  jump __L2
__L3:
; return;
  return_void
  return_void
.endfn

.fn ob_int 2 void
.param n i32
.param ob U8Array
.local tmp U8Array
.local len i32
.local v i32
.local i i32
; if n == 0 { ob_char('0', ob); return; }
  load n
  push_int 0
  eq
  jump_ifnot __L4
; if n == 0 { ob_char('0', ob); return; }
  push_int 48
  load ob
  call ob_char 2
  pop
; if n == 0 { ob_char('0', ob); return; }
  return_void
__L4:
; if n < 0 { ob_char('-', ob); n = 0 - n; }
  load n
  push_int 0
  lt
  jump_ifnot __L5
; if n < 0 { ob_char('-', ob); n = 0 - n; }
  push_int 45
  load ob
  call ob_char 2
  pop
; if n < 0 { ob_char('-', ob); n = 0 - n; }
  push_int 0
  load n
  sub
  store n
__L5:
; var tmp: U8Array = U8Array(12);
  push_int 12
  call U8Array 1
  store tmp
; var len: i32 = 0; var v: i32 = n;
  push_int 0
  store len
; var len: i32 = 0; var v: i32 = n;
  load n
  store v
; while v > 0 { set(tmp,len as u32,(48+v%10) as u8); len=len+1; v=v/10; }
__L6:
  load v
  push_int 0
  gt
  jump_ifnot __L7
; while v > 0 { set(tmp,len as u32,(48+v%10) as u8); len=len+1; v=v/10; }
  load tmp
  load len
  cast u32
  push_int 48
  load v
  push_int 10
  mod
  add
  cast u8
  call set 3
  pop
; while v > 0 { set(tmp,len as u32,(48+v%10) as u8); len=len+1; v=v/10; }
  load len
  push_int 1
  add
  store len
; while v > 0 { set(tmp,len as u32,(48+v%10) as u8); len=len+1; v=v/10; }
  load v
  push_int 10
  div
  store v
  jump __L6
__L7:
; var i: i32 = len - 1;
  load len
  push_int 1
  sub
  store i
; while i >= 0 { ob_char(get(tmp,i as u32),ob); i=i-1; }
__L8:
  load i
  push_int 0
  ge
  jump_ifnot __L9
; while i >= 0 { ob_char(get(tmp,i as u32),ob); i=i-1; }
  load tmp
  load i
  cast u32
  call get 2
  load ob
  call ob_char 2
  pop
; while i >= 0 { ob_char(get(tmp,i as u32),ob); i=i-1; }
  load i
  push_int 1
  sub
  store i
  jump __L8
__L9:
; delete(tmp);
  load tmp
  call delete 1
  pop
; return;
  return_void
  return_void
.endfn

