.fn main 0 i32
.local src_buf U8Array
.local tok_buf U8Array
.local out_buf U8Array
; var src_buf: U8Array = U8Array(131072);  // 128KB for source
  push_int 131072
  call U8Array 1
  store src_buf
; var tok_buf: U8Array = U8Array(4096);    // token string buffer
  push_int 4096
  call U8Array 1
  store tok_buf
; var out_buf: U8Array = U8Array(1048576); // 1MB output buffer (avoids mid-expression flush)
  push_int 1048576
  call U8Array 1
  store out_buf
; g_len = sys_read(0, src_buf, 131072u32);
  push_int 0
  load src_buf
  push_int 131072
  call sys_read 3
  store g_len
; g_pos = 0;
  push_int 0
  store g_pos
; g_line = 1;
  push_int 1
  store g_line
; g_ob_pos = 0;
  push_int 0
  store g_ob_pos
; lex_tok(src_buf, tok_buf);
  load src_buf
  load tok_buf
  call lex_tok 2
  pop
; pars_program(src_buf, tok_buf, out_buf);
  load src_buf
  load tok_buf
  load out_buf
  call pars_program 3
  pop
; ob_flush(out_buf);
  load out_buf
  call ob_flush 1
  pop
; delete(src_buf);
  load src_buf
  call delete 1
  pop
; delete(tok_buf);
  load tok_buf
  call delete 1
  pop
; delete(out_buf);
  load out_buf
  call delete 1
  pop
; return 0;
  push_int 0
  return
  return_void
.endfn

