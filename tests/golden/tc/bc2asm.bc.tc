  load len
  push_int 48
  load v
  push_int 10
  mod
  add
  cast u8
  call set U8Array i32 u8
  pop
; while v > 0 { set(tmp,len,(48+v%10) as u8); len=len+1; v=v/10; }
  load len
  push_int 1
  add
  store len
; while v > 0 { set(tmp,len,(48+v%10) as u8); len=len+1; v=v/10; }
  load v
  push_int 10
  div
  store v
  jump __L6
__L7:
; var i: i32 = len - 1;
  load len
  push_int 1
  sub
  store i
; while i >= 0 { ob_char(get(tmp,i),ob); i=i-1; }
__L8:
  load i
  push_int 0
  ge
  jump_ifnot __L9
; while i >= 0 { ob_char(get(tmp,i),ob); i=i-1; }
  load tmp
  load i
  call get U8Array i32
  load ob
  call ob_char u8 U8Array
  pop
; while i >= 0 { ob_char(get(tmp,i),ob); i=i-1; }
  load i
  push_int 1
  sub
  store i
  jump __L8
__L9:
; delete(tmp);
  load tmp
  call delete U8Array
  pop
; return;
  return_void
  return_void
.endfn

