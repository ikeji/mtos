.fn ob_flush U8Array void
.param ob U8Array
; if g_ob_pos > 0 { sys_write(1, ob, g_ob_pos); g_ob_pos = 0; }
  load g_ob_pos
  push_int 0
  gt
  jump_ifnot __L0
; if g_ob_pos > 0 { sys_write(1, ob, g_ob_pos); g_ob_pos = 0; }
  push_int 1
  load ob
  load g_ob_pos
  call sys_write i32 U8Array i32
  pop
; if g_ob_pos > 0 { sys_write(1, ob, g_ob_pos); g_ob_pos = 0; }
  push_int 0
  store g_ob_pos
__L0:
; return;
  return_void
  return_void
.endfn

.fn ob_char u8 U8Array void
.param c u8
.param ob U8Array
; set(ob, g_ob_pos, c);
  load ob
  load g_ob_pos
  load c
  call set U8Array i32 u8
  pop
; g_ob_pos = g_ob_pos + 1;
  load g_ob_pos
  push_int 1
  add
  store g_ob_pos
; if g_ob_pos >= 8192 { ob_flush(ob); }
  load g_ob_pos
  push_int 8192
  ge
  jump_ifnot __L1
; if g_ob_pos >= 8192 { ob_flush(ob); }
  load ob
  call ob_flush U8Array
  pop
__L1:
; return;
  return_void
  return_void
.endfn

.fn ob_n U8Array i32 i32 U8Array void
.param src U8Array
.param start i32
.param n i32
.param ob U8Array
.local i i32
; var i: i32 = 0;
  push_int 0
  store i
; while i < n { ob_char(get(src,(start+i)), ob); i = i + 1; }
__L2:
  load i
  load n
  lt
  jump_ifnot __L3
; while i < n { ob_char(get(src,(start+i)), ob); i = i + 1; }
  load src
  load start
  load i
  add
  call get U8Array i32
  load ob
  call ob_char u8 U8Array
  pop
; while i < n { ob_char(get(src,(start+i)), ob); i = i + 1; }
  load i
  push_int 1
  add
  store i
  jump __L2
__L3:
; return;
  return_void
  return_void
.endfn

.fn ob_int i32 U8Array void
.param n i32
.param ob U8Array
