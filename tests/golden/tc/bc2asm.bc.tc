__L5:
; var tmp: U8Array = U8Array(12);
  push_int 12
  call U8Array i32
  store tmp
; var len: i32 = 0; var v: i32 = n;
  push_int 0
  store len
; var len: i32 = 0; var v: i32 = n;
  load n
