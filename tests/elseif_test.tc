fn classify(x: i32) -> i32 {
    if x < 0 {
        return 0;
    } else if x == 0 {
        return 1;
    } else if x < 10 {
        return 2;
    } else {
        return 3;
    }
}

fn main() -> i32 {
    var a: i32 = classify(0 - 5);
    var b: i32 = classify(0);
    var c: i32 = classify(7);
    var d: i32 = classify(42);
    print(a);
    print(b);
    print(c);
    print(d);
    return 0;
}
