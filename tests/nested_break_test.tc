import "../compiler/runtime.tc";
// nested loops: inner break only exits inner loop
fn main() -> i32 {
    var result: i32 = 0;
    var i: i32 = 0;
    while i < 3 {
        var j: i32 = 0;
        while j < 10 {
            if j == 2 { break; }
            result = result + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}
