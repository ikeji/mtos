fn fizzbuzz(n: i32) -> i32 {
    var i: i32 = 1;
    while i <= n {
        if i % 15 == 0 {
            print("FizzBuzz");
        } else {
            if i % 3 == 0 {
                print("Fizz");
            } else {
                if i % 5 == 0 {
                    print("Buzz");
                } else {
                    print(i);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn main() -> i32 {
    return fizzbuzz(15);
}
