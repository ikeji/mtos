struct MyBuf {
    data: U8Array,
    pos: i32
}

fn len(mb: MyBuf) -> i32 {
    return pos(mb);
}

fn get(mb: MyBuf, idx: i32) -> u8 {
    return get(data(mb), idx);
}

fn main() -> i32 {
    var mb: MyBuf = MyBuf(U8Array(10), 0);
    set(data(mb), 0, 65 as u8);
    set(data(mb), 1, 66 as u8);
    pos(mb, 2);
    print_i32(len(mb));
    print_i32(get(mb, 0) as i32);
    print_i32(get(mb, 1) as i32);
    delete(data(mb));
    delete(mb);
    return 0;
}
