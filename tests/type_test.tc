// Type test: verify exact type matching with overloaded functions

fn double_val(x: i32) -> i32 {
    return x * 2;
}

fn double_val(x: u8) -> u8 {
    return x + x;
}

fn main() -> i32 {
    // i32 overload: double_val(21) = 42
    var a: i32 = double_val(21);
    print_i32(a);

    // u8 overload: double_val(33u8) = 66
    var b: u8 = double_val(33u8);
    print_i32(b as i32);

    // Builtin set/get with correct types
    var buf: U8Array = U8Array(1u32);
    set(buf, 0, 65u8);
    var c: i32 = get(buf, 0) as i32;
    print_i32(c);
    delete(buf);

    return 0;
}
