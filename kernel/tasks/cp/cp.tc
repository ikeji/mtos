// cp.tc — copy a file. Usage: `cp <src> <dst>`.
//
// dst must live on a writable FS (tmpfs). Source may be mtfs or
// tmpfs. Uses standard openat/read/write.

import "../libtc/libtc.tc";

var O_WRONLY: i32 = 1;
var O_CREAT:  i32 = 64;
var O_TRUNC:  i32 = 512;

fn main(argv: StringArray) -> i32 {
    if len(argv) < 3 {
        puts("cp: usage: cp <src> <dst>\n");
        return 1;
    }
    var src_fd: i32 = do_openat(0, get(argv, 1), 0);
    if src_fd < 0 {
        puts("cp: src open failed\n");
        return 1;
    }
    var dst_fd: i32 = do_openat(0, get(argv, 2),
                                O_WRONLY | O_CREAT | O_TRUNC);
    if dst_fd < 0 {
        puts("cp: dst open failed\n");
        do_close(src_fd);
        return 1;
    }
    var buf: U8Array = U8Array(4096);
    var done: i32 = 0;
    var err: i32 = 0;
    while done == 0 {
        var n: i32 = sys_read(src_fd, buf, 4096);
        if n <= 0 { done = 1; }
        else {
            var w: i32 = sys_write(dst_fd, buf, n);
            if w != n {
                puts("cp: write failed (short write)\n");
                err = 1;
                done = 1;
            }
        }
    }
    delete(buf);
    do_close(src_fd);
    do_close(dst_fd);
    return err;
}
