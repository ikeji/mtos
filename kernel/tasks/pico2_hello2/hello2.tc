// hello2.tc — guest task: prints "B" 5 times with busy wait

fn main() -> i32 {
    var buf: U8Array = U8Array(1);
    set(buf, 0, 'B');
    var i: i32 = 0;
    while i < 5 {
        sys_write(1, buf, 1);
        var j: i32 = 0;
        while j < 50000 { j = j + 1; }
        i = i + 1;
    }
    delete(buf);
    return 0;
}
