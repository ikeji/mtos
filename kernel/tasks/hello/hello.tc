// hello.tc — guest task: prints character from initialized global variable
// Platform-independent: busy-loop wait instead of mtime.

var g_char: u8 = 'A';
var g_count: i32 = 5;

fn main(argv: StringArray) -> i32 {
    var buf: U8Array = U8Array(1u32);
    set(buf, 0, g_char);
    var i: i32 = 0;
    while i < g_count {
        sys_write(1, buf, 1);
        var j: i32 = 0;
        while j < 50000 { j = j + 1; }
        i = i + 1;
    }
    delete(buf);
    return 0;
}
