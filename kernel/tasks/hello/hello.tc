// hello.tc — guest task: prints "A" 5 times then exits

fn main() -> i32 {
    var buf: U8Array = U8Array(1);
    set(buf, 0, 'A');
    var i: i32 = 0;
    while i < 5 {
        sys_write(1, buf, 1);
        // Busy wait to give timer a chance to preempt
        var j: i32 = 0;
        while j < 100000 {
            j = j + 1;
        }
        i = i + 1;
    }
    delete(buf);
    return 0;
}
